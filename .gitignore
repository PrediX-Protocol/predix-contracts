# ---------- Foundry build artifacts ----------
out/
cache/
broadcast/
.forge-snapshots/
packages/*/out/
packages/*/cache/
packages/*/broadcast/

# ---------- Node / package managers ----------
node_modules/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---------- Secrets & environment ----------
.env
.env.*
!.env.example
testenv.*
!testenv.example
*.pem
*.key
secrets/
.secrets/

# ---------- OS & editor ----------
.DS_Store
._*
Thumbs.db
Desktop.ini
*.swp
*.swo
*~
.vscode/
.idea/
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# ---------- Lock files we don't vendor ----------
foundry.lock

# ---------- Local development scratchpad ----------
*.tmp
*.bak
*.orig
*.rej
.tmp/
tmp/
scratch/

# ---------- Coverage & analysis ----------
coverage/
lcov.info
*.lcov
slither-out/
mythril-out/
echidna-corpus/
halmos-out/

# ---------- Internal working documents (not published) ----------
audits/
specs/**/REVIEW_*.md

# ---------- Agent prompts and rules (never publish on remote) ----------
CLAUDE.md
.claude/
AGENTS.md
CURSOR_RULES*.md
*_prompt.md

# ---------- Package-local forge libs (use monorepo lib/ only) ----------
packages/*/lib/

# ---------- Forge gas snapshots (generated by `forge snapshot`) ----------
.gas-snapshot
packages/*/.gas-snapshot

# ---------- Testnet / temporary helpers (not production scope) ----------
# Faucet + throwaway test-deployment contracts that live only to support
# testnet ops and do not belong in a mainnet/audit bundle. Keep locally but
# never commit. If one of these later promotes to production, lift the
# gitignore entry and re-commit deliberately with audit scope updated.
**/FaucetRelayed*.sol
**/TestFaucet*.sol
**/DeployFaucetRelayed*.sol
**/DeployTestFaucet*.sol
