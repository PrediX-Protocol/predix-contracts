# ============================================================================
# PrediX V2 deployment environment
# ============================================================================
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# Switch chain by replacing values below — do NOT edit deploy scripts.
# ============================================================================

# ---------- RPC endpoints ----------
# Primary RPC used by `forge script --rpc-url $UNICHAIN_RPC_PRIMARY`
UNICHAIN_RPC_PRIMARY=
# Backup RPC (manual fallback — not automatically used by forge)
UNICHAIN_RPC_BACKUP=

# ---------- Deployer ----------
# Testnet only — use hardware wallet for mainnet via `--ledger`
DEPLOYER_PRIVATE_KEY=
DEPLOYER_ADDRESS=

# ---------- Multisig + governance roles ----------
MULTISIG_ADDRESS=                       # DEFAULT_ADMIN_ROLE owner + Timelock proposer/executor
OPERATOR_ADDRESS=                       # OPERATOR_ROLE (emergencyResolve after 7d stall)
PAUSER_ADDRESS=                         # PAUSER_ROLE (pause facet modules)
REPORTER_ADDRESS=                       # REPORTER_ROLE on ManualOracle
REGISTRAR_ADDRESS=                      # REGISTRAR_ROLE on ChainlinkOracle (only if CHAINLINK_ENABLED=true)
FEE_RECIPIENT=                          # Receives creation fees + redemption fees + sweep

# ---------- Hook proxy ----------
HOOK_PROXY_ADMIN=                       # Separate key from MULTISIG — 48h timelock proxy admin
HOOK_RUNTIME_ADMIN=                     # Runtime admin (setPaused, setTrustedRouter). OK = MULTISIG.

# ---------- Timelock ----------
TIMELOCK_DELAY_SECONDS=172800           # 48 hours — matches hook proxy minimum

# Address of an existing TimelockController, when running DeployDiamond.s.sol in isolation.
# DeployAll.s.sol ignores this and deploys its own Timelock.
TIMELOCK_ADDRESS=

# ---------- Chain-specific addresses ----------
# The ONLY values that change when switching chain. Do NOT hardcode in scripts.
#
# USDC_ADDRESS:
#   - Mainnet: set to the canonical USDC address on the target chain
#     (Circle's deployment).
#   - Testnet: run `forge script packages/shared/script/DeployTestUSDC.s.sol:DeployTestUSDC`
#     first, then paste the deployed address here. TestUSDC is an open-mint
#     ERC20 with mainnet-matching metadata, intended to remove Circle faucet
#     rate limits while keeping the collateral interface identical.
USDC_ADDRESS=
POOL_MANAGER_ADDRESS=                   # Uniswap v4 PoolManager on target chain
PERMIT2_ADDRESS=0x000000000022D473030F116dDEE9F6B43aC78BA3   # Canonical across chains
V4_QUOTER_ADDRESS=                      # Uniswap v4-periphery V4Quoter on target chain

# TestUSDC initial supply override. Defaults to 1,000,000,000 USDC (raw:
# 1_000_000_000e6) minted to the deployer. Uncomment and override if a
# smaller float is desired on a particular testnet.
# TEST_USDC_INITIAL_SUPPLY=1000000000000000

# ---------- Chainlink (optional) ----------
# Set CHAINLINK_ENABLED=false on chains where Chainlink has no feeds yet
# (e.g., Unichain Sepolia). When false, deployment skips ChainlinkOracle and
# only deploys ManualOracle.
CHAINLINK_ENABLED=true
# Sequencer uptime feed (Chainlink convention). Leave blank on L1 or when
# CHAINLINK_ENABLED=false — ChainlinkOracle constructor accepts address(0) to
# skip the check (legitimate optional per ChainlinkOracle.sol lines 24-27).
CHAINLINK_SEQUENCER_UPTIME_FEED=

# ---------- Protocol parameters ----------
MARKET_CREATION_FEE=0                   # USDC raw (6 decimals); 0 = disabled
DEFAULT_PER_MARKET_CAP=0                # 0 = unlimited
DEFAULT_REDEMPTION_FEE_BPS=0            # 0..1500 (0.00%..15.00%); 0 = disabled

# ---------- v4 pool config (router immutables) ----------
LP_FEE_FLAG=8388608                     # 0x800000 = dynamic fee flag (per LPFeeLibrary)
TICK_SPACING=60                         # default tick spacing for binary pools

# ---------- DeployDiamond.s.sol standalone flag ----------
# DeployAll.s.sol ignores this and always finalizes. When running DeployDiamond
# in isolation, set false to keep deployer admin for follow-up scripts.
DIAMOND_FINALIZE_GOVERNANCE=false

# ---------- Populated after DeployAll / DeployDiamond ----------
# Written once by the orchestrator and then re-used by downstream isolated
# scripts. Leave blank for the first dry-run.
DIAMOND_ADDRESS=
EXCHANGE_ADDRESS=
HOOK_PROXY_ADDRESS=
